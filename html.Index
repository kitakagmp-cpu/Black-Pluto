<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>BLACK PLUTO — Elite Business Connections</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black:    #050508;
      --deep:     #0a0a12;
      --surface:  #111120;
      --border:   #1e1e35;
      --gold:     #c9a84c;
      --gold-dim: #7a5f25;
      --white:    #f0eff8;
      --muted:    #7070a0;
      --display:  'Bebas Neue', sans-serif;
      --body:     'Inter', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      color: var(--white);
      font-family: var(--body);
      font-size: 16px;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 6vw;
      background: rgba(5,5,8,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }

    .logo {
      font-family: var(--display);
      font-size: 1.6rem;
      letter-spacing: 0.12em;
      color: var(--white);
    }
    .logo span { color: var(--gold); }

    nav a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    nav a:hover { color: var(--gold); }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 10rem 6vw 6rem;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: -20%;
      right: -15%;
      width: 700px;
      height: 700px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(201,168,76,0.12) 0%, transparent 70%);
      pointer-events: none;
    }

    .hero::after {
      content: 'BP';
      position: absolute;
      right: 4vw;
      top: 50%;
      transform: translateY(-50%);
      font-family: var(--display);
      font-size: clamp(180px, 22vw, 340px);
      color: rgba(201,168,76,0.04);
      letter-spacing: -0.02em;
      pointer-events: none;
      user-select: none;
    }

    .hero-eyebrow {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
    }

    .hero h1 {
      font-family: var(--display);
      font-size: clamp(3.5rem, 9vw, 8rem);
      line-height: 0.92;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      max-width: 780px;
      margin-bottom: 2rem;
    }

    .hero h1 em {
      font-style: normal;
      color: var(--gold);
    }

    .hero p {
      font-size: 1.1rem;
      color: var(--muted);
      max-width: 480px;
      margin-bottom: 3rem;
      font-weight: 300;
      line-height: 1.8;
    }

    .btn-primary {
      display: inline-block;
      background: var(--gold);
      color: var(--black);
      font-weight: 700;
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 1rem 2.4rem;
      border: none;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
    }
    .btn-primary:hover {
      background: #e0bc60;
      transform: translateY(-2px);
    }

    /* ── STATS STRIP ── */
    .stats {
      display: flex;
      gap: 0;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background: var(--deep);
    }

    .stat {
      flex: 1;
      padding: 2.5rem 6vw;
      border-right: 1px solid var(--border);
    }
    .stat:last-child { border-right: none; }

    .stat-number {
      font-family: var(--display);
      font-size: 3rem;
      color: var(--gold);
      letter-spacing: 0.04em;
      line-height: 1;
    }

    .stat-label {
      font-size: 0.72rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 0.4rem;
    }

    /* ── HOW IT WORKS ── */
    .section {
      padding: 7rem 6vw;
    }

    .section-label {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }

    .section h2 {
      font-family: var(--display);
      font-size: clamp(2.4rem, 5vw, 4rem);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 4rem;
      max-width: 560px;
      line-height: 1.0;
    }

    .steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }

    .step {
      background: var(--deep);
      padding: 2.5rem 2rem;
      position: relative;
      transition: background 0.2s;
    }
    .step:hover { background: var(--surface); }

    .step-num {
      font-family: var(--display);
      font-size: 4rem;
      color: rgba(201,168,76,0.15);
      line-height: 1;
      margin-bottom: 1.2rem;
    }

    .step h3 {
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 0.6rem;
      color: var(--white);
    }

    .step p {
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.7;
    }

    /* ── CONTACT FORM ── */
    .contact-section {
      padding: 7rem 6vw;
      background: var(--deep);
      border-top: 1px solid var(--border);
    }

    .contact-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6vw;
      max-width: 1100px;
    }

    .contact-left h2 {
      font-family: var(--display);
      font-size: clamp(2.4rem, 5vw, 4rem);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      line-height: 1.0;
      margin-bottom: 1.5rem;
    }

    .contact-left p {
      font-size: 0.95rem;
      color: var(--muted);
      line-height: 1.8;
      max-width: 380px;
      margin-bottom: 2.5rem;
    }

    .contact-detail {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .contact-detail-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.85rem;
      color: var(--muted);
    }

    .contact-detail-item .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
    }

    form {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    label {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
    }

    input, select, textarea {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--white);
      font-family: var(--body);
      font-size: 0.9rem;
      padding: 0.85rem 1rem;
      outline: none;
      transition: border-color 0.2s;
      appearance: none;
      width: 100%;
    }

    input:focus, select:focus, textarea:focus {
      border-color: var(--gold);
    }

    input::placeholder, textarea::placeholder {
      color: #3a3a60;
    }

    select option {
      background: var(--surface);
    }

    textarea {
      resize: vertical;
      min-height: 120px;
    }

    .submit-row {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      margin-top: 0.5rem;
    }

    .form-note {
      font-size: 0.75rem;
      color: var(--muted);
    }

    .success-msg {
      display: none;
      background: rgba(201,168,76,0.1);
      border: 1px solid var(--gold-dim);
      color: var(--gold);
      padding: 1rem 1.25rem;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
    }

    /* ── FOOTER ── */
    footer {
      padding: 2rem 6vw;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.75rem;
      color: var(--muted);
      letter-spacing: 0.08em;
    }

    footer .logo { font-size: 1.1rem; }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .stats { flex-direction: column; }
      .stat { border-right: none; border-bottom: 1px solid var(--border); }
      .stat:last-child { border-bottom: none; }
      .contact-inner { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
      .hero::after { display: none; }
      footer { flex-direction: column; gap: 0.5rem; text-align: center; }
    }

    @media (prefers-reduced-motion: reduce) {
      * { transition: none !important; }
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo">BLACK <span>PLUTO</span></div>
  <a href="#connect">Connect Now</a>
</nav>

<!-- HERO -->
<section class="hero">
  <p class="hero-eyebrow">Elite Business Network</p>
  <h1>Where Power<br>Meets <em>Purpose</em></h1>
  <p>Black Pluto connects serious business minds. No noise — just direct lines to the people who move markets, close deals, and build empires.</p>
  <a href="#connect" class="btn-primary">Request a Connection</a>
</section>

<!-- STATS -->
<div class="stats">
  <div class="stat">
    <div class="stat-number">5K+</div>
    <div class="stat-label">Business Leaders</div>
  </div>
  <div class="stat">
    <div class="stat-number">120+</div>
    <div class="stat-label">Industries</div>
  </div>
  <div class="stat">
    <div class="stat-number">98%</div>
    <div class="stat-label">Match Rate</div>
  </div>
  <div class="stat">
    <div class="stat-number">48H</div>
    <div class="stat-label">Avg. Response</div>
  </div>
</div>

<!-- HOW IT WORKS -->
<section class="section">
  <p class="section-label">The Process</p>
  <h2>How Black Pluto Works</h2>
  <div class="steps">
    <div class="step">
      <div class="step-num">01</div>
      <h3>Submit Your Profile</h3>
      <p>Tell us who you are, what you do, and who you need to meet. We vet every member.</p>
    </div>
    <div class="step">
      <div class="step-num">02</div>
      <h3>We Find the Match</h3>
      <p>Our team identifies the right connections from our network based on your goals and industry.</p>
    </div>
    <div class="step">
      <div class="step-num">03</div>
      <h3>Direct Introduction</h3>
      <p>You receive a warm, direct introduction — no cold outreach, no middlemen lingering.</p>
    </div>
    <div class="step">
      <div class="step-num">04</div>
      <h3>Build & Close</h3>
      <p>Take it from there. Partnerships, deals, ventures — Black Pluto opened the door.</p>
    </div>
  </div>
</section>

<!-- CONTACT FORM -->
<section class="contact-section" id="connect">
  <div class="contact-inner">
    <div class="contact-left">
      <p class="section-label">Get Connected</p>
      <h2>Start Your First Connection</h2>
      <p>Fill in your details and tell us what kind of business contact you're looking for. Our team will reach out within 48 hours.</p>
      <div class="contact-detail">
        <div class="contact-detail-item">
          <span class="dot"></span>
          <span>hello@blackpluto.co</span>
        </div>
        <div class="contact-detail-item">
          <span class="dot"></span>
          <span>Responses within 48 hours</span>
        </div>
        <div class="contact-detail-item">
          <span class="dot"></span>
          <span>All inquiries are confidential</span>
        </div>
      </div>
    </div>

    <div>
      <div class="success-msg" id="successMsg">
        ✦ Your request has been received. We'll be in touch within 48 hours.
      </div>
      <form id="contactForm">
        <div class="form-row">
          <div class="field">
            <label for="fname">First Name</label>
            <input type="text" id="fname" placeholder="John" required />
          </div>
          <div class="field">
            <label for="lname">Last Name</label>
            <input type="text" id="lname" placeholder="Doe" required />
          </div>
        </div>
        <div class="field">
          <label for="email">Business Email</label>
          <input type="email" id="email" placeholder="john@company.com" required />
        </div>
        <div class="field">
          <label for="company">Company / Title</label>
          <input type="text" id="company" placeholder="CEO, Acme Corp" />
        </div>
        <div class="field">
          <label for="industry">Your Industry</label>
          <select id="industry">
            <option value="" disabled selected>Select industry</option>
            <option>Finance & Investment</option>
            <option>Technology</option>
            <option>Real Estate</option>
            <option>Manufacturing</option>
            <option>Healthcare</option>
            <option>Media & Entertainment</option>
            <option>Legal & Consulting</option>
            <option>Other</option>
          </select>
        </div>
        <div class="field">
          <label for="message">Who Are You Looking to Connect With?</label>
          <textarea id="message" placeholder="Describe the type of business partner, investor, or contact you're seeking..."></textarea>
        </div>
        <div class="submit-row">
          <button type="submit" class="btn-primary">Send Request</button>
          <span class="form-note">Confidential & secure</span>
        </div>
      </form>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="logo">BLACK <span style="color:var(--gold)">PLUTO</span></div>
  <span>© 2026 Black Pluto. All rights reserved.</span>
</footer>

<script>
  document.getElementById('contactForm').addEventListener('submit', function(e) {
    e.preventDefault();
    this.style.display = 'none';
    document.getElementById('successMsg').style.display = 'block';
  });
</script>

</body>
</html>
